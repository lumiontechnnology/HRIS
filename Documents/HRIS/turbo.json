{
  "extends": ["//"],
  "globalDependencies": ["**/.env"],
  "pipeline": {
    "type-check": {
      "outputs": []
    },
    "lint": {
      "outputs": [],
      "cache": false
    },
    "format": {
      "outputs": [],
      "cache": false
    },
    "test": {
      "outputs": []
    },
    "build": {
      "outputs": [".next", "dist", ".turbo/cache"],
      "cache": false,
      "dependsOn": ["^build", "type-check"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "outputs": []
    },
    "db:migrate": {
      "outputs": []
    },
    "db:seed": {
      "outputs": []
    }
  }
}
