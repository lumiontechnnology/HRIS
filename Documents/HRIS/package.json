{
  "name": "lumion-hris",
  "version": "1.0.0",
  "description": "Production-grade Human Resource Information System",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20 <25",
    "npm": ">=10 <11"
  },
  "scripts": {
    "postinstall": "pnpm --filter @lumion/database db:generate",
    "prebuild": "pnpm --filter @lumion/database db:generate",
    "dev": "turbo dev --filter='./apps/*'",
    "build": "turbo build",
    "build:web": "pnpm --filter @lumion/database db:generate && pnpm --filter @lumion/web build",
    "test": "turbo test",
    "test:watch": "turbo test -- --watch",
    "test:coverage": "turbo test -- --coverage",
    "lint": "turbo lint",
    "lint:ci": "turbo lint -- --max-warnings=0",
    "lint:hardening:phase1": "eslint \"apps/web/src/app/(auth)/**/*.{ts,tsx}\" \"apps/web/src/lib/**/*.{ts,tsx}\" --max-warnings=0 --rule \"@typescript-eslint/no-unused-vars:error\" --rule \"@typescript-eslint/no-non-null-assertion:error\" --rule \"@typescript-eslint/await-thenable:error\"",
    "lint:hardening:phase2": "eslint \"apps/web/src/app/(dashboard)/**/*.{ts,tsx}\" --max-warnings=0 --rule \"@typescript-eslint/no-unused-vars:error\" --rule \"@typescript-eslint/restrict-template-expressions:error\"",
    "format": "turbo format",
    "type-check": "turbo type-check",
    "verify:uat": "npx turbo db:generate && npx turbo type-check && npx turbo build",
    "verify:release": "npx turbo db:generate && npx turbo lint -- --max-warnings=0 && npx turbo type-check && npx turbo build",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed",
    "prisma:studio": "cd packages/database && npx prisma studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "turbo": "^1.11.3",
    "typescript": "^5.3.3"
  },
  "dependencies": {},
  "volta": {
    "node": "20.20.1"
  }
}
