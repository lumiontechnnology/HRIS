{
  "buildCommand": "pnpm --filter @lumion/database db:generate && pnpm --filter @lumion/web build",
  "installCommand": "PRISMA_SKIP_POSTINSTALL_GENERATE=true pnpm install --frozen-lockfile",
  "framework": "nextjs",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- apps/web/ packages/",
  "crons": [
    {
      "path": "/api/cron/leave-accrual",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/mark-absences",
      "schedule": "59 23 * * *"
    },
    {
      "path": "/api/cron/process-exits",
      "schedule": "59 23 * * *"
    }
  ]
}
