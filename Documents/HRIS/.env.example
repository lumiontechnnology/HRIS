# ============================================================================
# DATABASE - SUPABASE (PostgreSQL)
# ============================================================================
# Use your Supabase project connection string from: https://app.supabase.com/
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres?sslmode=require

# ============================================================================
# AUTHENTICATION - SUPABASE
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# API Configuration
# ============================================================================
API_URL=http://localhost:3001
API_INTERNAL_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================================================
# File Storage - AWS S3
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=lumion-hris-dev

# ============================================================================
# Cache - Redis
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# Email Service - Resend
# ============================================================================
RESEND_API_KEY=

# ============================================================================
# Error Tracking - Sentry
# ============================================================================
SENTRY_DSN=

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info

