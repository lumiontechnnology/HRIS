# ============================================================================
# DATABASE - NEON (PostgreSQL)
# ============================================================================
# Get connection string from: https://console.neon.tech/
# Format: postgresql://[user]:[password]@[host]/[database]
DATABASE_URL=postgresql://username:password@ep-xxxx.region.neon.tech/lumion_hris?sslmode=require

# ============================================================================
# AUTHENTICATION - CLERK
# ============================================================================
# Get keys from: https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk webhook secret for syncing user data
# Set up webhook at: https://dashboard.clerk.com/apps/[app-id]/webhooks
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redirect URL after sign-in/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard/onboarding

# ============================================================================
# API Configuration
# ============================================================================
API_URL=http://localhost:3001
API_INTERNAL_URL=http://localhost:3001

# ============================================================================
# File Storage - AWS S3
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=lumion-hris-dev

# ============================================================================
# Cache - Redis
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# Email Service - Resend
# ============================================================================
RESEND_API_KEY=

# ============================================================================
# Error Tracking - Sentry
# ============================================================================
SENTRY_DSN=

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info

