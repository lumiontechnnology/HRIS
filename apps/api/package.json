{
  "name": "@lumion/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test": "tsx --test src/**/*.test.ts",
    "test:watch": "tsx --test --watch src/**/*.test.ts",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@lumion/database": "workspace:*",
    "@lumion/types": "workspace:*",
    "@lumion/validators": "workspace:*",
    "@prisma/client": "^5.7.1",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@supabase/supabase-js": "^2.49.8",
    "cors": "^2.8.5",
    "csv-stringify": "^6.7.0",
    "hono": "^3.12.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^4.6.11",
    "resend": "^4.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.6",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
